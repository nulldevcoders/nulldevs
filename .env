PORT=3000
NODE_ENV=production

# Email (SMTP) — fill these in to actually send emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
CONTACT_TO=hello@nulldevs.io
CONTACT_FROM=noreply@nulldevs.io

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CONTACT_RATE_LIMIT_MAX=5
